cmake_minimum_required(VERSION 3.25)
project(@SOKOL_VARIANT_NAME@ LANGUAGES C @SOKOL_OBJC@)

set(SOKOL_SRC_DIR "@SOKOL_SRC_DIR@")

# sokol_app and sokol_glue contain a main() entry point and a reference to the
# application's _sokol_main callback, so they cannot be built as shared
# libraries (unresolved symbol at link time). The other components are fine.
if("@SOKOL_COMPONENT@" STREQUAL "app" OR "@SOKOL_COMPONENT@" STREQUAL "glue")
  add_library(@SOKOL_VARIANT_NAME@ STATIC sokol_impl.c)
else()
  add_library(@SOKOL_VARIANT_NAME@ sokol_impl.c)
endif()

target_include_directories(@SOKOL_VARIANT_NAME@ PUBLIC
  $<BUILD_INTERFACE:${SOKOL_SRC_DIR}>
  $<BUILD_INTERFACE:${CMAKE_INSTALL_PREFIX}/include>
  $<INSTALL_INTERFACE:include>
)

set_target_properties(@SOKOL_VARIANT_NAME@ PROPERTIES
  C_STANDARD 11
  POSITION_INDEPENDENT_CODE ON
)

if(WIN32 AND BUILD_SHARED_LIBS AND NOT ("@SOKOL_COMPONENT@" STREQUAL "app" OR "@SOKOL_COMPONENT@" STREQUAL "glue"))
  target_compile_definitions(@SOKOL_VARIANT_NAME@ PUBLIC SOKOL_DLL)
endif()

if(APPLE)
  if("@SOKOL_BACKEND@" STREQUAL "METAL" OR "@SOKOL_COMPONENT@" STREQUAL "app" OR "@SOKOL_COMPONENT@" STREQUAL "glue")
    target_compile_options(@SOKOL_VARIANT_NAME@ PRIVATE -x objective-c)
  endif()
  if("@SOKOL_BACKEND@" STREQUAL "METAL")
    target_link_libraries(@SOKOL_VARIANT_NAME@ PRIVATE
      "-framework AppKit"
      "-framework Metal"
      "-framework MetalKit"
      "-framework Cocoa"
      "-framework QuartzCore"
    )
  elseif("@SOKOL_BACKEND@" STREQUAL "GLCORE")
    target_link_libraries(@SOKOL_VARIANT_NAME@ PRIVATE "-framework OpenGL")
  endif()
  # sokol_app always needs Cocoa on macOS regardless of backend.
  if("@SOKOL_COMPONENT@" STREQUAL "app")
    target_link_libraries(@SOKOL_VARIANT_NAME@ PRIVATE
      "-framework AppKit"
      "-framework Cocoa"
      "-framework QuartzCore"
    )
  endif()
endif()

if(WIN32 AND "@SOKOL_BACKEND@" STREQUAL "D3D11")
  target_link_libraries(@SOKOL_VARIANT_NAME@ PRIVATE d3d11 dxgi)
endif()

if("@SOKOL_BACKEND@" STREQUAL "WGPU")
  # The WGPU backend needs the Dawn monolithic library. For shared variants we
  # link it now; static variants leave it unresolved for the final executable.
  if(BUILD_SHARED_LIBS)
    target_link_directories(@SOKOL_VARIANT_NAME@ PRIVATE "${CMAKE_INSTALL_PREFIX}/lib")
    target_link_libraries(@SOKOL_VARIANT_NAME@ PRIVATE webgpu_dawn)
  endif()
endif()

install(TARGETS @SOKOL_VARIANT_NAME@
  EXPORT @SOKOL_VARIANT_NAME@Targets
  ARCHIVE DESTINATION lib
  LIBRARY DESTINATION lib
  RUNTIME DESTINATION bin
)
install(FILES
  ${SOKOL_SRC_DIR}/sokol_@SOKOL_COMPONENT@.h
  DESTINATION include
)
if("@SOKOL_COMPONENT@" STREQUAL "glue")
  install(FILES
    ${SOKOL_SRC_DIR}/sokol_gfx.h
    ${SOKOL_SRC_DIR}/sokol_app.h
    DESTINATION include
  )
endif()

install(EXPORT @SOKOL_VARIANT_NAME@Targets
  FILE @SOKOL_VARIANT_NAME@Targets.cmake
  NAMESPACE @SOKOL_VARIANT_NAME@::
  DESTINATION lib/cmake/@SOKOL_VARIANT_NAME@
)
